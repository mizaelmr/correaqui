generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Category {
  BURACO
  RUA_ALAGADA
  LIXO_ACUMULADO
  ILUMINACAO_PUBLICA
  VAZAMENTO_AGUA
  ESGOTO
  ARVORE_CAIDA
  OBRA_ABANDONADA
  FALTA_PAVIMENTACAO
  OUTRO
}

enum Severity {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

enum OccurrenceStatus {
  ABERTA
  EM_ANALISE
  AGUARDANDO_VALIDACAO
  RESOLVIDA
}

enum UserRole {
  CIDADAO
  PREFEITURA
  ADMIN
}

enum TimelineEventType {
  CRIADA
  FOTOS_ADICIONADAS
  CONFIRMADA
  STATUS_ALTERADO
  RESOLUCAO_SOLICITADA
  RESOLUCAO_APROVADA
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  phone         String?
  image         String?
  password      String?
  role          UserRole  @default(CIDADAO)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  occurrences    Occurrence[]
  confirmations  Confirmation[]
  passwordResets PasswordReset[]
}

model PasswordReset {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Occurrence {
  id            String           @id @default(cuid())
  title         String
  description   String
  category      Category
  severity      Severity
  status        OccurrenceStatus @default(ABERTA)
  latitude      Float
  longitude     Float
  address       String
  neighborhood  String?
  city          String?
  state         String?
  reporterName  String?
  reporterPhone String?
  confirmations  Int              @default(0)
  showReporter   Boolean          @default(false)
  userId        String?
  user          User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  photos        Photo[]
  timeline      TimelineEvent[]
  confirmationsList Confirmation[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([status])
  @@index([category])
  @@index([severity])
  @@index([userId])
  @@index([latitude, longitude])
}

model Confirmation {
  id           String     @id @default(cuid())
  occurrenceId String
  userId       String
  occurrence   Occurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([occurrenceId, userId])
}

model Photo {
  id           String     @id @default(cuid())
  url          String
  occurrence   Occurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  occurrenceId String
  createdAt    DateTime   @default(now())
}

model TimelineEvent {
  id           String            @id @default(cuid())
  type         TimelineEventType
  description  String
  occurrence   Occurrence        @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  occurrenceId String
  createdAt    DateTime          @default(now())
}

model ResolutionRequest {
  id            String   @id @default(cuid())
  occurrenceId  String
  userId        String?
  comment       String?
  reporterName  String?
  reporterPhone String?
  photos        String[]
  createdAt     DateTime @default(now())
}
